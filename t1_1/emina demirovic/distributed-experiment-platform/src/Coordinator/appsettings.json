{
  "Coordinator": {
    "DatabasePath": "Data/coordinator.db"
  },

  "Raft": {
    "NodeId": "coordinator-1",
    "HeartbeatIntervalMilliseconds": 500,
    "AutomaticElectionEnabled": false,
    "ClientCommandReplicationEnabled": false,
    "ElectionTimeoutMinMilliseconds": 1500,
    "ElectionTimeoutMaxMilliseconds": 3000,
    "CommandReplicationTimeoutMilliseconds": 5000,
    "CommandReplicationPollMilliseconds": 100,
    "Peers": [
      {
        "NodeId": "coordinator-2",
        "BaseUrl": "http://localhost:5032"
      },
      {
        "NodeId": "coordinator-3",
        "BaseUrl": "http://localhost:5033"
      }
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  
  "AllowedHosts": "*"
}